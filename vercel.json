{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron-process-reminders",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/process-campaign-messages",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/process-intake-messages",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/cron/monthly-billing",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/retry-failed-payments",
      "schedule": "0 15 * * *"
    }
  ],
  "functions": {
    "src/pages/api/cron-process-reminders.ts": {
      "maxDuration": 30
    },
    "src/pages/api/process-intake-messages.ts": {
      "maxDuration": 30
    },
    "src/pages/api/cron/monthly-billing.ts": {
      "maxDuration": 60
    },
    "src/pages/api/cron/retry-failed-payments.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/cron-process-reminders",
      "destination": "/api/cron-process-reminders"
    }
  ]
} 